# Database - AWS RDS PostgreSQL
DATABASE_URL=postgresql://{{ db_username }}:{{ db_password }}@{{ db_host }}:{{ db_port }}/{{ db_name }}?schema=public

DB_HOST={{ db_host }}
DB_PORT={{ db_port }}
DB_USER={{ db_username }}
DB_PASSWORD={{ db_password }}
DB_NAME={{ db_name }}

# Auth
BETTER_AUTH_URL=http://{{ app_public_dns }}:3000
BETTER_AUTH_SECRET={{ better_auth_secret }}

# App
NEXT_PUBLIC_APP_NAME=NextCRM
NEXT_PUBLIC_APP_URL=http://{{ app_public_dns }}:3000

# Required for encrypted values stored in DB
EMAIL_ENCRYPTION_KEY={{ email_encryption_key }}

# Initial admin account
ADMIN_EMAIL={{ admin_email }}
TEST_USER_EMAIL={{ admin_email }}

# S3-compatible storage - AWS S3
NEXT_PUBLIC_MINIO_ENDPOINT=https://{{ s3_bucket_name }}.s3.{{ aws_region }}.amazonaws.com
MINIO_ENDPOINT=https://s3.{{ aws_region }}.amazonaws.com
MINIO_PORT=443
MINIO_BUCKET={{ s3_bucket_name }}
MINIO_USE_SSL=true
MINIO_ACCESS_KEY={{ s3_access_key }}
MINIO_SECRET_KEY={{ s3_secret_key }}

# Disable local MinIO bucket creation logic
CREATE_MINIO_BUCKET=false

# Inngest
INNGEST_DEV=1
INNGEST_ID=nextcrm
INNGEST_APP_NAME=NextCRM
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=
INNGEST_BASE_URL=http://inngest:8288

# Optional integrations
OPENAI_API_KEY={{ openai_api_key | default('sk-placeholder-replace-to-enable-ai') }}
RESEND_API_KEY={{ resend_api_key | default('re_placeholder_replace_to_enable_email') }}
RESEND_FROM_EMAIL={{ resend_from_email | default('') }}

GOOGLE_ID={{ google_id | default('') }}
GOOGLE_SECRET={{ google_secret | default('') }}
FIRECRAWL_API_KEY={{ firecrawl_api_key | default('') }}
E2B_API_KEY={{ e2b_api_key | default('') }}